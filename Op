local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local CoreGui = game:GetService("CoreGui")

-- Configuration
local KEYBOARD_TITLE = "GOLDEN KEYBOARD"
local GOLD_COLOR = Color3.fromRGB(255, 215, 0)
local DARK_GOLD = Color3.fromRGB(139, 101, 8)
local PRESSED_COLOR = Color3.fromRGB(255, 255, 255)
local BG_COLOR = Color3.fromRGB(20, 20, 20)

-- UI Setup
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "GoldenKeyboardUI"
ScreenGui.ResetOnSpawn = false
ScreenGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
-- Try to parent to CoreGui for executor compatibility, fallback to PlayerGui
local success, err = pcall(function() ScreenGui.Parent = CoreGui end)
if not success then ScreenGui.Parent = game:GetService("Players").LocalPlayer:WaitForChild("PlayerGui") end

local MainFrame = Instance.new("Frame")
MainFrame.Name = "MainFrame"
MainFrame.Size = UDim2.new(0, 500, 0, 200)
MainFrame.Position = UDim2.new(0.5, -250, 0.8, -100)
MainFrame.BackgroundColor3 = BG_COLOR
MainFrame.BorderSizePixel = 2
MainFrame.BorderColor3 = GOLD_COLOR
MainFrame.Active = true
MainFrame.Draggable = true
MainFrame.Parent = ScreenGui

local UIStroke = Instance.new("UIStroke")
UIStroke.Thickness = 2
UIStroke.Color = GOLD_COLOR
UIStroke.Parent = MainFrame

local Title = Instance.new("TextLabel")
Title.Size = UDim2.new(1, 0, 0, 25)
Title.BackgroundTransparency = 1
Title.Text = KEYBOARD_TITLE
Title.TextColor3 = GOLD_COLOR
Title.TextSize = 14
Title.Font = Enum.Font.GothamBold
Title.Parent = MainFrame

local KeysContainer = Instance.new("Frame")
KeysContainer.Size = UDim2.new(0.95, 0, 0.75, 0)
KeysContainer.Position = UDim2.new(0.025, 0, 0.2, 0)
KeysContainer.BackgroundTransparency = 1
KeysContainer.Parent = MainFrame

local UIGridLayout = Instance.new("UIGridLayout")
UIGridLayout.CellSize = UDim2.new(0, 40, 0, 40)
UIGridLayout.CellPadding = UDim2.new(0, 5, 0, 5)
UIGridLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
UIGridLayout.Parent = KeysContainer

local keyLabels = {}

-- Define keys to display
local keysToShow = {
    "Q", "W", "E", "R", "T", "Y", "U", "I", "O", "P",
    "A", "S", "D", "F", "G", "H", "J", "K", "L",
    "Shift", "Z", "X", "C", "V", "B", "N", "M", "Space"
}

-- Create Key Visuals
for _, keyName in ipairs(keysToShow) do
    local KeyFrame = Instance.new("Frame")
    KeyFrame.Name = keyName
    KeyFrame.BackgroundColor3 = DARK_GOLD
    KeyFrame.BorderSizePixel = 0
    KeyFrame.Parent = KeysContainer
    
    local UICorner = Instance.new("UICorner")
    UICorner.CornerRadius = UDim.new(0, 4)
    UICorner.Parent = KeyFrame
    
    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = keyName == "Space" and "_" or keyName
    Label.TextColor3 = GOLD_COLOR
    Label.TextSize = 12
    Label.Font = Enum.Font.GothamBold
    Label.Parent = KeyFrame
    
    keyLabels[keyName:upper()] = KeyFrame
end

-- Key Press Logic
local function animateKey(keyName, pressed)
    local frame = keyLabels[keyName:upper()]
    if frame then
        local targetColor = pressed and PRESSED_COLOR or DARK_GOLD
        local targetText = pressed and BG_COLOR or GOLD_COLOR
        
        TweenService:Create(frame, TweenInfo.new(0.1), {BackgroundColor3 = targetColor}):Play()
        TweenService:Create(frame.TextLabel, TweenInfo.new(0.1), {TextColor3 = targetText}):Play()
    end
end

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local keyName = input.KeyCode.Name
        if keyLabels[keyName:upper()] then
            animateKey(keyName, true)
        elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
            animateKey("Shift", true)
        elseif input.KeyCode == Enum.KeyCode.Space then
            animateKey("Space", true)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input, gameProcessed)
    if input.UserInputType == Enum.UserInputType.Keyboard then
        local keyName = input.KeyCode.Name
        if keyLabels[keyName:upper()] then
            animateKey(keyName, false)
        elseif input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
            animateKey("Shift", false)
        elseif input.KeyCode == Enum.KeyCode.Space then
            animateKey("Space", false)
        end
    end
end)
